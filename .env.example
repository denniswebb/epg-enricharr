# Environment Configuration Template
# Copy to .env and customize for your local setup

# Dispatcharr Instance
DISPATCHARR_HOST=http://localhost:8000
DISPATCHARR_PORT=8000
DISPATCHARR_DB_PATH=./data/db.sqlite3

# EPG Test Data
EPG_TEST_DATA_PATH=./tests/fixtures/sample-epg.xml
EPG_OUTPUT_PATH=./tests/output/enriched-epg.xml

# Development Settings
DEBUG=True
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# Plugin Configuration
PLUGIN_VERSION=1.0.0
PLUGIN_AUTHOR=epg-enricharr-team
